### .env file content ###

# Environment type (required)
# Valid values: qa, dev, prod
ENV=qa

# Global timeout in milliseconds (optional, default: 10000)
# Used for Playwright operations throughout the framework
TIMEOUT=10000

# Slow motion delay in milliseconds (optional, default: 0)
# Slows down operations - useful for debugging
SLOW_MO=0

# Example of using testing data from the .env file. This approach is great for sensitive information.
PERMANENT_ADDRESS="Testing Permanent Address loaded from .env file."
### End of .env file ###